VITE_API_URL=http://localhost:3000/api/v1
VITE_LIVEKIT_URL=ws://localhost:7880

# Optional: hard-override tenant for unauthenticated requests so the
# patient app talks to a specific clinic before login. In multi-tenant
# subdomain setups leave empty. In dev/single-clinic — paste the clinic
# UUID. Wins over auth.store.tenantId — see apps/web-patient/src/lib/api.ts
# VITE_TENANT_ID=00000000-0000-0000-0000-000000000002
