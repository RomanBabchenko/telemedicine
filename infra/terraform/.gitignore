# Local .terraform directories
.terraform/
.terraform.lock.hcl

# .tfstate files (contain secrets and the EIP)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable files (contain SSH keys and IPs)
terraform.tfvars
*.auto.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Plan output
*.tfplan
