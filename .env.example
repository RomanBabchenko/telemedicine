# ============================================
# Telemed Platform — environment variables
# Copy to .env and adjust for your local setup.
# ============================================

NODE_ENV=development

# ---- API ----
API_PORT=3000
API_GLOBAL_PREFIX=api/v1
# Comma-separated. Each entry is either a literal origin, or a regex prefixed
# with `regex:` (useful for whitelisting LAN subnets when developing across
# devices, e.g. `regex:^http://192\.168\.\d+\.\d+:5173$`).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,regex:^http://192\.168\.\d+\.\d+:(5173|5174|5175)$,regex:^http://10\.\d+\.\d+\.\d+:(5173|5174|5175)$

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=telemed
DB_PASSWORD=telemed
DB_NAME=telemed
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- JWT / Auth ----
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_TTL=30d

# ---- MinIO (S3) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=telemed
MINIO_SECRET_KEY=telemed-secret
MINIO_BUCKET=telemed-files
MINIO_REGION=us-east-1

# ---- LiveKit ----
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret
# IP that the LiveKit container advertises in ICE candidates. Must be the
# dev box's LAN IP so phones on the same Wi-Fi can connect.
# Find yours with: ip -4 -o addr show | grep -v ' lo '
LIVEKIT_NODE_IP=192.168.88.251

# ---- SMTP (MailHog in dev) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Telemed Platform <noreply@telemed.local>"

# ---- Tenant ----
PLATFORM_TENANT_ID=00000000-0000-0000-0000-000000000001

# ---- Adapters ----
PAYMENT_PROVIDER=stub
DOCDREAM_STUB_ENABLED=true

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:3000/api/v1
VITE_LIVEKIT_URL=ws://localhost:7880
